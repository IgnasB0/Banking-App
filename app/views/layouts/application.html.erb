<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Transaction Manager" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Transaction Manager">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if authenticated? %>
      <nav class="nav">
        <span class="nav-brand">Transaction Manager</span>
        <div class="nav-actions">
          <span class="nav-user"><%= Current.user.email_address %></span>
          <%= button_to "Sign out", session_path, method: :delete, class: "btn btn-secondary btn-sm" %>
        </div>
      </nav>
    <% end %>

    <% if flash[:alert] %>
      <div class="flash flash-alert"><%= flash[:alert] %></div>
    <% end %>
    <% if flash[:notice] %>
      <div class="flash flash-notice"><%= flash[:notice] %></div>
    <% end %>

    <main class="main">
      <%= yield %>
    </main>
  </body>
</html>
