<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Banking App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="stylesheet" href="/app.css">
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if authenticated? %>
      <nav>
        <a href="/" class="logo">Banking App</a>
        <a href="/">Accounts</a>
        <a href="/accounts/new.html">New Account</a>
        <a href="/transfers/new.html">Transfer</a>
        <span class="nav-user"><%= Current.user.email_address %></span>
        <%= button_to "Sign out", session_path, method: :delete, class: "btn btn-secondary btn-sm" %>
      </nav>
    <% end %>

    <% if flash[:alert] %>
      <div class="flash flash-alert"><%= flash[:alert] %></div>
    <% end %>
    <% if flash[:notice] %>
      <div class="flash flash-notice"><%= flash[:notice] %></div>
    <% end %>

    <main>
      <%= yield %>
    </main>
  </body>
</html>
