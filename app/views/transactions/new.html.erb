<% content_for :title, "New Transfer" %>

<div class="auth-container">
  <div class="auth-card">
    <h1 class="auth-title">New Transfer</h1>

    <% if @error %>
      <div class="flash flash-alert" style="margin-bottom: 16px; border-radius: 6px;"><%= @error %></div>
    <% end %>

    <%= form_with url: transactions_path, class: "auth-form" do |form| %>
      <div class="form-group">
        <%= form.label :from_account_id, "From account" %>
        <%= form.select :from_account_id,
              Current.user.accounts.map { |a| ["#{a.first_name} #{a.last_name} — #{a.iban}", a.id] },
              { prompt: "Select your account" },
              { name: "transaction[from_account_id]", class: "form-input" } %>
      </div>

      <div class="form-group">
        <%= form.label :to_iban, "Recipient IBAN" %>
        <%= form.text_field :to_iban,
              name: "transaction[to_iban]",
              placeholder: "e.g. GB29NWBK60161331926819",
              class: "form-input",
              autocomplete: "off" %>
      </div>

      <div class="form-group">
        <%= form.label :amount, "Amount" %>
        <%= form.number_field :amount,
              name: "transaction[amount]",
              placeholder: "0.00",
              min: "0.01",
              step: "0.01",
              class: "form-input" %>
      </div>

      <%= form.submit "Send", class: "btn btn-primary btn-full" %>
    <% end %>
  </div>
</div>
